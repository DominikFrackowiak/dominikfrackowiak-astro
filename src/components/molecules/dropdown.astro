---
import { cn } from '@/utils/cn'


interface Props {
	className?: string
	buttonVariant?: 'icon-button' | 'regular' | 'go-back' | 'simple'
}

const { className, buttonVariant = 'icon-button' } = Astro.props
---

<div class='relative flex flex-col items-center' data-dropdown>
	<button
		aria-expanded='false'
		class={cn('text-light text-2xl border-none cursor-pointer', className)}
		data-dropdown-trigger
	>
		<slot name='trigger' />
	</button>
	<div
		class='absolute right-0 top-full mt-3 min-w-36 bg-light p-3 text-dark shadow-lg dark:bg-dark dark:text-light hidden'
		data-dropdown-content
	>
		<slot />
	</div>
</div>

<script>
	function initDropdowns() {
		const dropdowns = document.querySelectorAll('[data-dropdown]')

		dropdowns.forEach(dropdown => {
			if (!(dropdown instanceof HTMLElement) || dropdown.dataset.bound === 'true') {
				return
			}

			const trigger = dropdown.querySelector('[data-dropdown-trigger]')
			const content = dropdown.querySelector('[data-dropdown-content]')

			if (!(trigger instanceof HTMLElement) || !(content instanceof HTMLElement)) {
				return
			}

			dropdown.dataset.bound = 'true'

			trigger.addEventListener('click', event => {
				event.stopPropagation()

				const dropdownContents = document.querySelectorAll(
					'[data-dropdown-content]',
				)

				if (content.classList.contains('hidden')) {
					dropdownContents.forEach(content => {
						content.classList.remove('flex')
						content.classList.add('hidden')
					})
					content.classList.remove('hidden')
					content.classList.add('flex')
				} else {
					content.classList.add('hidden')
					content.classList.remove('flex')
				}
			})
		})
	}

	function closeDropdowns() {
		document.querySelectorAll('[data-dropdown-content]').forEach(content => {
			content.classList.remove('flex')
			content.classList.add('hidden')
		})
	}

	if (document.documentElement.dataset.dropdownsGlobalBound !== 'true') {
		document.documentElement.dataset.dropdownsGlobalBound = 'true'

		document.body.addEventListener('click', closeDropdowns)

		document.body.addEventListener('keydown', event => {
			if (event.key === 'Escape') {
				closeDropdowns()
			}
		})
	}

	initDropdowns()
	document.addEventListener('astro:page-load', initDropdowns)
</script>
