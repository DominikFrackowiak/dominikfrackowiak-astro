---
import { useTranslations, getLangFromUrl } from '@/i18n/utils'
const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
import Layout from '../../layouts/Layout.astro'
import Hero from '../organisms/hero.astro'
import HeadingTextBlock from '../organisms/heading-text-block.astro'
import Technologies from '../organisms/technologies.astro'
import ExperienceItem from '../molecules/experience-item.astro'
import { experience } from '@/constants/experience'
---

<Layout title='Home'>
	<Hero />

	<HeadingTextBlock headingText='TECHNOLOGIES'>
		<Technologies />
	</HeadingTextBlock>
	<HeadingTextBlock headingText={t('experience.section.title')}>
		{
			experience.map(el => (
				<ExperienceItem
					company={t(el.company)}
					position={t(el.position)}
					description={t(el.description)}
					technologies={el.technologies}
				/>
			))
		}
	</HeadingTextBlock>
</Layout>
