---
import { cn } from "@/utils/cn"
interface Props{
 className?: string
 variant?: 'icon-button' | 'regular' | 'go-back' 
}

const buttonVariants = {
  'icon-button': 'text-light text-2xl border-none',
  'regular': 'text-dark dark:text-light border border-dark dark:border-light rounded-4xl px-3 py-1.5 text-sm',
  'go-back': 'text-lg text-accent',
  'simple': 'text-lg border-none underline text-dark dark:text-light'
}

const {className, variant='regular'} = Astro.props
---

<button class={cn(buttonVariants[variant], className)}>
  <slot/>
</button>