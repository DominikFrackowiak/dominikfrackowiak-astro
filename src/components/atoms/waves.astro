---
import waveSvg from '@/assets/new-wave2.svg?raw'

type Props = {
	class?: string
	lineCount?: number
	amplitude?: number
	wavelength?: number
	speed?: number
	tilt?: number
	densityEase?: number
}

const {
	class: className = '',
	lineCount = 44,
	amplitude = 42,
	wavelength = 190,
	speed = 0.8,
	tilt = 0.16,
	densityEase = 1.35,
} = Astro.props

const svgMarkup = waveSvg
	.replace(/<!--[\s\S]*?-->/g, '')
	.replace(
		/<svg\b/,
		`<svg data-topographic-wave data-line-count="${lineCount}" data-amplitude="${amplitude}" data-wavelength="${wavelength}" data-speed="${speed}" data-tilt="${tilt}" data-density-ease="${densityEase}" class="${className}" preserveAspectRatio="none"`,
	)
---

<Fragment set:html={svgMarkup} />

<script>
	const svgs = document.querySelectorAll('[data-topographic-wave]')

	svgs.forEach(svg => {
		if (!(svg instanceof SVGSVGElement)) return

		const viewBox = svg.viewBox.baseVal
		const width = viewBox?.width || 1200
		const height = viewBox?.height || 700
		const paddingY = height * 0.05
		const samples = 120

		const desiredLineCount = Number(svg.dataset.lineCount)
		const amplitude = Number(svg.dataset.amplitude)
		const wavelength = Number(svg.dataset.wavelength)
		const speed = Number(svg.dataset.speed)
		const tilt = Number(svg.dataset.tilt)
		const densityEase = Number(svg.dataset.densityEase)

		const group = svg.querySelector('g')
		const sourcePaths = Array.from(svg.querySelectorAll('path'))

		if (!group || sourcePaths.length === 0) return

		while (sourcePaths.length < desiredLineCount) {
			const path = sourcePaths[sourcePaths.length - 1].cloneNode()
			group.append(path)
			sourcePaths.push(path as SVGPathElement)
		}

		const paths = sourcePaths.slice(0, desiredLineCount)
		const lineCount = paths.length

		const usableHeight = height - paddingY * 2
		const xStep = width / samples

		let start: number | null = null
		let rafId: number | null = null

		function getPath(i: number, time: number) {
			const motion = time * speed
			const centerBias = lineCount / 2
			const progress = lineCount > 1 ? i / (lineCount - 1) : 0
			const yBase = paddingY + Math.pow(progress, densityEase) * usableHeight
			const distanceFromCenter = (i - centerBias) / centerBias
			const lineAmp = amplitude * (1 - Math.abs(distanceFromCenter) * 0.22)
			const depthScale = 1 - Math.abs(distanceFromCenter) * tilt
			const localPhase = i * 0.24

			let d = ''

			for (let s = 0; s <= samples; s++) {
				const x = s * xStep
				const waveA = Math.sin(x / wavelength + motion + localPhase) * lineAmp
				const waveB =
					Math.sin(x / (wavelength * 0.55) - motion * 0.6 + i * 0.08) *
					(lineAmp * 0.18)
				const waveC =
					Math.cos(x / (wavelength * 1.8) + motion * 0.4) * (lineAmp * 0.1)
				const y = yBase + (waveA + waveB + waveC) * depthScale

				d += `${s === 0 ? 'M' : 'L'}${x.toFixed(2)} ${y.toFixed(2)} `
			}

			return d.trim()
		}

		function animate(now: number) {
			if (start === null) start = now

			const elapsed = (now - start) / 1000

			paths.forEach((path, i) => {
				path.setAttribute('d', getPath(i, elapsed))
				path.setAttribute('opacity', String(0.08 + (i / (lineCount - 1)) * 0.92))
			})

			rafId = requestAnimationFrame(animate)
		}

		function stopAnimation() {
			if (rafId !== null) cancelAnimationFrame(rafId)
			rafId = null
		}

		rafId = requestAnimationFrame(animate)
		document.addEventListener('astro:before-swap', stopAnimation, { once: true })
		window.addEventListener('beforeunload', stopAnimation, { once: true })
	})
</script>
