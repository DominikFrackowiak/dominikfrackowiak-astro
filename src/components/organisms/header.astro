---
import Logo from '@/components/atoms/logo.astro'
import CenteringWrapper from '@/components/atoms/centering-wrapper.astro'
import ScrollIndicator from '../molecules/scroll-indicator.astro'
import HeaderActions from './header-actions.tsx'
---

<header class='fixed top-0 left-0 w-screen bg-dark dark:bg-accent py-3.5'>
	<ScrollIndicator />
	<CenteringWrapper className='justify-between items-center'>
		<Logo />
		<HeaderActions client:load />
	</CenteringWrapper>
</header>

<script>
	const applyTheme = () => {
		document.documentElement.classList.toggle(
			'dark',
			localStorage.theme === 'dark' ||
				(!('theme' in localStorage) &&
					window.matchMedia('(prefers-color-scheme: dark)').matches)
		)
	}

	applyTheme()
</script>
