---
import Image from 'astro/components/Image.astro'
import portrait from '@/assets/images/dominikfrackowiak2.webp'
import Button from '../atoms/button.astro'
import wavesUrl from '@/assets/new-wave2.svg?url'
import CenteringWrapper from '../atoms/centering-wrapper.astro'

// pt-50
---

<section
	class='flex min-h-screen w-full gap-20 pb-40 waves-bg relative overflow-hidden'
	style={`background-image: url(${wavesUrl});`}
>
	<div
		class='absolute top-0 left-0 h-screen w-full bg-light/60 dark:bg-dark/20'
	>
	</div>
	<CenteringWrapper className='flex justify-between items-center pt-52 z-10'>
		<div class='flex justify-start w-2/6'>
			<Image
				src={portrait}
				alt="Dominik's Frackowiak portrait"
				class='h-34 w-34 rounded-full border-2 border-accent z-10'
			/>
		</div>
		<div class='flex flex-col gap-4 items-end w-[44%] pt-20'>
			<!-- <Image
				src={portrait}
				alt="Dominik's Frackowiak portrait"
				class='h-34 w-34 rounded-full border-2 border-accent z-10'
			/> -->
			<p
				class='text-dark dark:text-light text-justify text-hero! leading-8! font-extralight!'
			>
				Hola, soy Dominik Frąckowiak. Frontend developer basado en Madrid.
				Trabajo principalmente con React, Next.js y Astro. Este sitio reúne
				proyectos, notas y experimentos personales.
			</p>
			<div class='flex w-full gap-4 justify-end!'>
				<Button as='a' variant='regular' href='/es/projects'
					>Contacta cónmigo</Button
				>
				<Button as='a' variant='cta' href='/es/projects'
					>Ver los proyectos</Button
				>
			</div>
		</div>
	</CenteringWrapper>

	<style>
		.waves-bg {
			background-position: center top;
			background-repeat: no-repeat;
			background-size: cover;
		}
	</style>
</section>
