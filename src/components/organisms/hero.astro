---
import Image from 'astro/components/Image.astro'
import portrait from '@/assets/images/dominikfrackowiak2.webp'
import Button from '../atoms/button.astro'
import CenteringWrapper from '../atoms/centering-wrapper.astro'
import Waves from '../atoms/waves.astro'

// pt-50
---

<section
	class='flex min-h-[65vh] w-full gap-20 pb-40 waves-bg relative isolate overflow-hidden pt-20'
>
	<Waves
		class='absolute inset-0 z-0 h-full w-full text-accent'
		lineCount={44}
		amplitude={42}
		wavelength={165}
		speed={0.8}
		tilt={0.16}
		densityEase={1.35}
	/>
	<div
		class='absolute top-0 left-0 z-1 h-screen w-full bg-light/60 dark:bg-dark/40'
	>
	</div>
	<CenteringWrapper
		className='flex justify-between items-center pt-20 relative z-10'
	>
		<div class='flex justify-start w-2/6'>
			<Image
				src={portrait}
				alt="Dominik's Frackowiak portrait"
				class='h-32 w-32 rounded-full border-2 border-accent z-10'
			/>
		</div>
		<div class='flex flex-col gap-4 items-end w-[44%] pt-5'>
			<!-- <Image
				src={portrait}
				alt="Dominik's Frackowiak portrait"
				class='h-34 w-34 rounded-full border-2 border-accent z-10'
			/> -->
			<p
				class='text-dark dark:text-light text-justify text-hero! leading-6 dark:leading-8! font-normal! dark:font-light!'
			>
				Hola, soy Dominik Frąckowiak. Frontend developer basado en Madrid.
				Trabajo principalmente con React, Next.js y Astro. Este sitio reúne
				proyectos, notas y experimentos personales.
			</p>
			<div class='flex w-full gap-4 justify-end!'>
				<Button as='a' variant='regular' href='/es/projects'
					>Contacta cónmigo</Button
				>
				<Button as='a' variant='cta' href='/es/projects'
					>Ver los proyectos</Button
				>
			</div>
		</div>
	</CenteringWrapper>
</section>
